## Server
PORT=9000
NODE_ENV=development

## Database
MONGODB_URI=mongodb+srv://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_CLUSTER.mongodb.net
DATABASE_NAME=your-database-name

## JWT
JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_EXPIRES_IN=7d

## Redis (Cloud)
REDIS_HOST=CHANGE_ME_REDIS_HOST
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

## Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
FROM_EMAIL=your-email@gmail.com
EMAIL_FROM=Your App Name <your-email@gmail.com>

## App
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8080,http://localhost:3001


