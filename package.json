{
  "name": "founder-club",
  "version": "1.0.0",
  "description": "Scalable Node.js + Express backend template with MongoDB, Zod, Redis, BullMQ, global error handling, and response helpers.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node --env-file=.env src/server.js",
    "worker": "node --env-file=.env src/worker.js",
    "worker:dev": "node --watch --env-file=.env src/worker.js",
    "lint": "node -e \"console.log('No linter configured. Add eslint if you want.')\""
  },
  "dependencies": {
    "bullmq": "^5.58.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.15",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.2.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  }
}


